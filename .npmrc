# Electron 及打包工具下载镜像（使用 npmmirror，末尾斜杠不可省略）
# electron_mirror — Electron 运行时本体（electron-v41.0.0-darwin-x64.zip 等）
# electron_builder_binaries_mirror — electron-builder 打包工具（dmgbuild、nsis、wine 等）
# 备用 GitHub 直链（网络可达时可切换）：
# electron_mirror=https://github.com/electron/electron/releases/download/v
electron_mirror=https://registry.npmmirror.com/-/binary/electron/
electron_custom_dir={{ version }}
electron_builder_binaries_mirror=https://registry.npmmirror.com/-/binary/electron-builder-binaries/
